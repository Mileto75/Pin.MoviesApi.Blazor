<div class="col col-lg-3 m-1">
    <div class="card p-1" style="width: 18rem;">
        <img src="@Movie.ImgPoster" class="card-img-top" alt="...">
        <div class="card-body">
            <h5 class="card-title">@Movie.Title</h5>
            <a class="btn btn-outline-info" @onclick="@(() => OnInfo.InvokeAsync(Movie))">Info</a>
        </div>
    </div>
</div>
@code {
    [Parameter]
    public MovieModel Movie { get; set; }
    [Parameter]
    public EventCallback<MovieModel> OnInfo { get; set; }
}
